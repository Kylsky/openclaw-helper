{
  "name": "openclaw-installer",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw 助手（Tauri）。提供检测/控制台/卸载等能力，并逐步迁移原 Electron 安装逻辑。",
  "main": "src/main/main.js",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "gen:icons": "node scripts/generate-icons.js",
    "diag:openclaw": "node scripts/diagnose-openclaw.js",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "build": {
    "appId": "com.openclaw.installer",
    "productName": "OpenClaw 助手",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
