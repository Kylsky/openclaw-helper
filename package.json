{
  "name": "openclaw-installer",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw 一体化安装与控制台（Windows/macOS）。自动准备 nvm/node/git，并全局安装 openclaw。",
  "main": "src/main/main.js",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "gen:icons": "node scripts/generate-icons.js",
    "diag:openclaw": "node scripts/diagnose-openclaw.js",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "build": {
    "appId": "com.openclaw.installer",
    "productName": "OpenClaw 助手",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
